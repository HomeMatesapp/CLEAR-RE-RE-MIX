  "rules": [
    {
      "id": "r_block_no_placements",
      "when": {
        "all": [
          {
            "questionId": "placement_commitment",
            "op": "eq",
            "value": "no"
          }
        ]
      },
      "then": [
        {
          "kind": "block_route",
          "routeId": "route_ug_degree",
          "reason": "Every qualifying route includes substantial assessed placements \u2014 there is no placement-free route to registration.",
          "evidenceRefs": [
            "ev_basw_routes"
          ]
        },
        {
          "kind": "block_route",
          "routeId": "route_pg_masters",
          "reason": "Every qualifying route includes substantial assessed placements \u2014 there is no placement-free route to registration.",
          "evidenceRefs": [
            "ev_basw_routes"
          ]
        },
        {
          "kind": "block_route",
          "routeId": "route_apprenticeship",
          "reason": "Every qualifying route includes substantial assessed placements \u2014 there is no placement-free route to registration.",
          "evidenceRefs": [
            "ev_basw_routes"
          ]
        },
        {
          "kind": "block_route",
          "routeId": "route_step_up",
          "reason": "Every qualifying route includes substantial assessed placements \u2014 there is no placement-free route to registration.",
          "evidenceRefs": [
            "ev_basw_routes"
          ]
        },
        {
          "kind": "block_route",
          "routeId": "route_approach",
          "reason": "Every qualifying route includes substantial assessed placements \u2014 there is no placement-free route to registration.",
          "evidenceRefs": [
            "ev_basw_routes"
          ]
        }
      ]
    },
    {
      "id": "r_block_fasttrack_sw_degree",
