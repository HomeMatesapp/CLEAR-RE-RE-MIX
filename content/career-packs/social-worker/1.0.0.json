  "requirements": [
    {
      "id": "req_swe_registration",
      "label": "Registration with Social Work England",
      "description": "'Social worker' is a protected title in England. To practise you must complete an approved qualification and register with Social Work England.",
      "verifiedBy": "Social Work England register",
      "evidenceRefs": [
        "ev_swe_registration"
      ],
      "requirementType": "participant_verification"
    },
    {
      "id": "req_enhanced_dbs",
      "label": "Enhanced DBS check",
      "description": "An enhanced criminal record check is required for training and practice. Flags rarely rule people out automatically, but get advice early.",
      "verifiedBy": "Enhanced DBS check arranged by your course or employer",
      "evidenceRefs": [
        "ev_basw_routes"
      ],
      "requirementType": "participant_verification"
    },
    {
      "id": "req_gcse_english",
      "label": "GCSE English at grade 4/C or above (or approved equivalent)",
      "description": "Approved courses and the funded programmes require GCSE English (many also require maths).",
      "verifiedBy": "Certificate check by the course provider",
      "evidenceRefs": [
        "ev_dfe_step_up",
        "ev_dfe_approach",
        "ev_basw_routes"
      ],
      "requirementType": "machine_assessable",
      "machineRule": {
        "all": [
          {
            "questionId": "gcse_english_maths_status",
            "op": "in",
            "value": [
              "both",
              "english_only"
            ]
          }
        ]
      }
    },
    {
      "id": "req_level3",
      "label": "Level 3 qualification for undergraduate entry",
      "description": "Undergraduate social work degrees normally require a Level 3 qualification. A completed degree also satisfies this.",
      "verifiedBy": "UCAS application / certificate check",
      "evidenceRefs": [
        "ev_basw_routes",
        "ev_prospects_courses"
      ],
      "requirementType": "machine_assessable",
      "machineRule": {
        "any": [
          {
            "questionId": "level3_status",
            "op": "eq",
            "value": "yes"
          },
          {
            "questionId": "degree_status",
            "op": "in",
            "value": [
              "degree_2_2_plus",
              "degree_below_2_2",
              "social_work_degree"
            ]
          }
        ]
      }
    },
    {
      "id": "req_degree_any",
      "label": "An undergraduate degree",
      "description": "Postgraduate routes require an undergraduate degree.",
      "verifiedBy": "Certificate check by the course provider",
      "evidenceRefs": [
        "ev_prospects_courses"
      ],
      "requirementType": "machine_assessable",
      "machineRule": {
        "all": [
          {
            "questionId": "degree_status",
            "op": "in",
            "value": [
              "degree_2_2_plus",
              "degree_below_2_2"
            ]
          }
        ]
      }
    },
    {
      "id": "req_degree_2_2",
      "label": "A 2:2 or above in a subject other than social work",
      "description": "The funded fast-track programmes require at least a 2:2 honours degree (any subject except social work). Some accept a predicted 2:2 in your final year.",
      "verifiedBy": "Certificate check by the programme",
      "evidenceRefs": [
        "ev_gov_step_up",
        "ev_dfe_approach"
      ],
      "requirementType": "machine_assessable",
      "machineRule": {
        "all": [
          {
            "questionId": "degree_status",
            "op": "eq",
            "value": "degree_2_2_plus"
          }
        ]
      }
    },
    {
      "id": "req_experience_6m",
      "label": "6 months' direct experience with vulnerable groups",
      "description": "Step Up to Social Work requires 6 months' full-time (or equivalent) paid or voluntary experience with vulnerable children, young people, families, carers or vulnerable adults.",
      "verifiedBy": "Declared and evidenced in your Step Up application",
      "evidenceRefs": [
        "ev_gov_step_up",
        "ev_dfe_step_up"
      ],
      "requirementType": "machine_assessable",
      "machineRule": {
        "all": [
          {
            "questionId": "vulnerable_experience_6m",
            "op": "eq",
            "value": "yes"
          }
        ]
      }
    },
    {
      "id": "req_employer_backing",
      "label": "An employer to sponsor the apprenticeship",
      "description": "Degree apprenticeships are jobs with training: you need an employer (often your current one in social care) willing to put you through the apprenticeship.",
      "verifiedBy": "Agreement with your employer",
      "evidenceRefs": [
        "ev_communitycare_routes",
        "ev_basw_routes"
      ],
      "requirementType": "machine_assessable",
      "machineRule": {
        "all": [
          {
            "questionId": "employer_support",
            "op": "eq",
            "value": "yes_employer_sponsor"
          }
        ]
      }
    }
  ],
  "questionRefs": [
