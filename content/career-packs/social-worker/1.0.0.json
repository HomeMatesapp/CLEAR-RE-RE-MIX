        "all": [
          {
            "questionId": "degree_status",
            "op": "eq",
            "value": "social_work_degree"
          }
        ]
      },
      "then": [
        {
          "kind": "block_route",
          "routeId": "route_step_up",
          "reason": "Step Up is only open to people who do not already hold a social work degree.",
