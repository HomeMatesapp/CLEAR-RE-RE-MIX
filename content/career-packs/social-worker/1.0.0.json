            "ev_gov_step_up"
          ]
        },
        {
          "kind": "block_route",
          "routeId": "route_approach",
          "reason": "Approach Social Work is for graduates of subjects other than social work.",
          "evidenceRefs": [
            "ev_dfe_approach"
          ]
        },
        {
          "kind": "add_consideration",
